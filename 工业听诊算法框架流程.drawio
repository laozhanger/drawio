        <mxCell id="example3" value="• 置信度0.55>阈值0.50 → AI判定异常(低置信度)" style="text;html=1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=5;fontSize=11;whiteSpace=wrap;fillColor=#f7f7f9;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="1610" y="545" width="760" height="25" as="geometry" />
        </mxCell>
        <mxCell id="example4" value="  但多个探测器同时检测强烈振动 → 判定为&quot;严重&quot;故障" style="text;html=1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=15;fontSize=11;whiteSpace=wrap;fillColor=#f7f7f9;strokeColor=#666666;fontStyle=1;" parent="1" vertex="1">
