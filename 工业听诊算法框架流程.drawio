        <mxCell id="param4" value="置信度阈值: AI模型输出异常分数的可信程度(0-1),用于判断是否异常" style="text;html=1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=5;fontSize=11;whiteSpace=wrap;fillColor=#f7f7f9;strokeColor=#666666;" parent="1" vertex="1">
