        </mxCell>
        <mxCell id="param5" value="传统信号幅度阈值: 过滤未运行工况等安静声音(推荐:0.001-0.01)" style="text;html=1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=5;fontSize=11;whiteSpace=wrap;fillColor=#f7f7f9;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="1610" y="210" width="760" height="35" as="geometry" />
        </mxCell>
 
        <!-- 置信度 vs 严重程度 说明 -->
        <mxCell id="diff_title" value="置信度 vs 严重程度 区别" style="swimlane;horizontal=0;fillColor=#f7f7f9;fontSize=14;fontStyle=1;align=left;verticalAlign=middle;spacingTop=8;spacingLeft=15;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="1600" y="260" width="800" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="diff_table" value="┌──────────────────┬──────────────────────────────────────┬──────────────────────────┐&#xa;│      维度        │           置信度阈值                │     故障严重程度         │&#xa;├──────────────────┼──────────────────────────────────────┼──────────────────────────┤&#xa;│ 定义             │ AI模型输出异常分数的可信程度        │ 故障对设备运行的影响程度 │&#xa;│ 作用阶段         │ 算法判断阶段(单次检测)             │ 最终决策阶段(综合评估)   │&#xa;│ 取值范围         │ 0~1                                  │ 轻微/中等/严重           │&#xa;│ 物理意义         │ &quot;模型有多少把握认为这是异常&quot;       │ &quot;这个问题危害有多大&quot;     │&#xa;└──────────────────┴──────────────────────────────────────┴──────────────────────────┘" style="text;html=1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=5;fontSize=9;whiteSpace=wrap;fillColor=#f7f7f9;strokeColor=#666666;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="1610" y="310" width="760" height="110" as="geometry" />
        </mxCell>
 
        <!-- 示例说明 -->
        <mxCell id="example_title" value="示例说明" style="swimlane;horizontal=0;fillColor=#f7f7f9;fontSize=14;fontStyle=1;align=left;verticalAlign=middle;spacingTop=8;spacingLeft=15;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="1600" y="440" width="800" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="example1" value="• 置信度0.92>阈值0.90 → AI判定异常(高置信度)" style="text;html=1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=5;fontSize=11;whiteSpace=wrap;fillColor=#f7f7f9;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="1610" y="490" width="760" height="25" as="geometry" />
        </mxCell>
        <mxCell id="example2" value="  但可能是轻微摩擦 → 判定为&quot;轻微&quot;故障" style="text;html=1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=15;fontSize=11;whiteSpace=wrap;fillColor=#f7f7f9;strokeColor=#666666;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1610" y="515" width="760" height="25" as="geometry" />
